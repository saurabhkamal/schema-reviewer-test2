    "@tanstack/react-query": "^5.50.1",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "axios": "^1.7.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "install": "^0.13.0",
    "lint-staged": "^15.2.7",
    "next": "14.2.4",
    "npm": "^10.8.1",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
